<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ description or site.description }}">
  <link rel="stylesheet" href="/assets/css/site.css">
</head>
<body>
  <div class="site-shell">
    <button
      class="nav-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="site-sidebar"
      aria-label="Open navigation"
      data-nav-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="mobile-topbar">
      <a class="mobile-brand" href="/">{{ site.title }}</a>
    </div>

    <aside class="site-sidebar" id="site-sidebar" data-sidebar>
      <div class="sidebar-inner">
        <a class="brand" href="/">{{ site.title }}</a>

        <nav class="site-nav">
          {% for item in nav %}
            <a
              href="{{ item.url }}"
              {% if item.external %}target="_blank" rel="noopener noreferrer"{% endif %}
            >
              {{ item.title }}
            </a>
          {% endfor %}
        </nav>

        <div class="sidebar-note">
          <p>{{ site.tagline }}</p>
          <a class="sidebar-link" href="{{ site.unschoolPagesUrl }}">Visit Unschool Pages</a>
        </div>
      </div>
    </aside>

    <button class="site-overlay" type="button" aria-label="Close navigation" data-overlay></button>

    <div class="site-main">
      <main class="wrap">
        {{ content | safe }}
      </main>

      <footer class="site-footer">
        <div class="wrap footer-inner">
          <p>{{ site.title }} — {{ site.tagline }}</p>
          <p><a href="{{ site.unschoolPagesUrl }}">Visit Unschool Pages</a></p>
        </div>
      </footer>
    </div>
  </div>

  <script src="/assets/js/site.js"></script>
</body>
</html>
