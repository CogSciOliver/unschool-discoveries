---
layout: layouts/base.njk
---

<section class="hero">
  <p class="eyebrow">Welcome to the story world</p>
  <h1>{{ title }}</h1>
  <p class="lead">{{ intro }}</p>

  <div class="actions">
    <a class="button button-frost" href="{{ site.unschoolPagesUrl }}">Explore the Unschool Pages</a>
    <a class="button button-ghost" href="/books/venturing-into-the-unknown/">Claim A Free Ebook</a>

  </div>
</section>

{% set featured = (books | selectattr("featured") | list | first) %}

{% if featured %}
<section class="panel">
  <div class="grid two">
    <div>
      <img src="{{ featured.cover }}" alt="{{ featured.title }} cover">
    </div>
    <div>
      <p class="eyebrow">Featured Book</p>
      <h2>{{ featured.title }}</h2>
      <p>{{ featured.hook }}</p>
      <p><strong>Formats:</strong> {{ featured.formats | join(", ") }}</p>
      <a class="button" href="{{ featured.url }}">View Book</a>
    </div>
  </div>
</section>
{% endif %}


{% from "components/card-grid.njk" import cardGrid %}
{% set items = [
{
"title": "New here?",
"text": "Get oriented fast.",
"image": "https://mri.unschooldiscoveries.com/explore.png",
"image_alt": "Explore the story world",
"href": "/start-here/",
"button_label": "Start Here",
"external": false
},
{
"title": "Investigate the Story World",
"text": "Follow clues, themes, and reader trails.",
"eyebrow": false,
"image": "https://mri.unschooldiscoveries.com/investigate.png",
"image_alt": "Investigate the story world",
"href": "/investigate/",
"button_label": "Investigate",
"external": false
},
{
"title": "Media",
"text": "Press info, images, and releases.",
"eyebrow": false,
"image": "https://mri.unschooldiscoveries.com/publish.png",
"image_alt": "Media resources",
"href": "/media/",
"button_label": "View Media",
"external": false
},
{
"title": "Purchase the Book",
"text": "Get your copy today.",
"eyebrow": false,
"image": "https://mri.unschooldiscoveries.com/research.png",
"image_alt": "Unschool Discoveries book",
"href":site.amazonBundleUrl,
"button_label": "Order Now",
"external": true
}
] %}

<section class="panel">
  <h2>Choose your path</h2>
  {{ cardGrid(items, "four") }}
</section>


{% from "components/single-panel.njk" import singlePanel %}
{{ singlePanel(
title="Continue on Unschool Pages",
text="The living notebook, rabbit holes, and behind-the-scenes publication platform.",
href="{{ site.unschoolPagesUrl }}",
button_label="Go to Unschool Pages",
external=true
) }}

{% from "components/single-panel.njk" import singlePanel %}
{{ singlePanel(
title="Explore the Book",
text="Discover the book's themes, clues, and connections.",
href="/books/venturing-into-the-unknown/",
button_label="View Book"
) }}

{% from "components/single-panel.njk" import singlePanel %}
{{ singlePanel(
title="Stay in the loop",
text="Get book news, release updates, and new discoveries.",
href=site.newsletterSignUpUrl,
button_label="Join the Newsletter",
external=true
) }}